# Copy this file to .env and fill in your values.
# Never commit .env – it is listed in .gitignore.
#
# Load into your shell with:
#   export $(grep -v '^#' .env | xargs)
# or use a tool like direnv / dotenv.

# ── Required credentials ──────────────────────────────────────────────────────

# Your Octopus Energy OAuth2 refresh token.
# Obtain it from the Octopus developer portal or by inspecting an authenticated
# browser session (see sanitize_har.sh for help with HAR files).
OCTOPUS_REFRESH_TOKEN=

# The OAuth2 client ID issued to the Octoplus web app.
OCTOPUS_CLIENT_ID=

# ── Optional tuning ───────────────────────────────────────────────────────────

# How often the claim command polls for a reward to be issued (default: 2s).
# CLAIM_POLL_INTERVAL=2s

# How long the claim command waits before giving up (default: 60s).
# CLAIM_POLL_TIMEOUT=60s

# How often the watch command checks for offer availability (default: 30s).
# WATCH_INTERVAL=30s

# Logging level: debug | info | warn | error  (default: info)
# LOG_LEVEL=info

# Logging format: text | json  (default: text)
# LOG_FORMAT=text

